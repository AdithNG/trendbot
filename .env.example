# Copy this file to .env and fill in your Alpaca API keys
# Get keys from: https://app.alpaca.markets/paper/dashboard/overview

ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paper trading URL (default — safe for testing)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Switch to this for live trading (REAL MONEY):
# ALPACA_BASE_URL=https://api.alpaca.markets
